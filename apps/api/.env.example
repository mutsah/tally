# ── Server ────────────────────────────────────────────────────────────────
PORT=3002                                   # Port the API listens on
NODE_ENV=development                        # development | production
ALLOWED_ORIGINS=http://localhost:3000       # Comma-separated CORS origins
FRONTEND_URL=http://localhost:3000          # Web app base URL (OAuth redirects)
APP_URL=http://localhost:3002/              # This API's own base URL

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tally  # Postgres connection string

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-access-secret          # Secret for signing access tokens
JWT_REFRESH_SECRET=change-me-refresh-secret # Secret for signing refresh tokens (must differ)
JWT_EXPIRES_IN=900                           # Access token lifetime in seconds

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                            # Google OAuth client ID
GOOGLE_CLIENT_SECRET=                        # Google OAuth client secret
GOOGLE_CALLBACK_URL=                         # e.g. http://localhost:3002/api/v1/auth/google/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=                            # GitHub OAuth client ID
GITHUB_CLIENT_SECRET=                        # GitHub OAuth client secret
GITHUB_CALLBACK_URL=                         # e.g. http://localhost:3002/api/v1/auth/github/callback

# ── SMTP (transactional email) ────────────────────────────────────────────
SMTP_HOST=                                   # SMTP server host
SMTP_PORT=587                                # SMTP server port (587 = STARTTLS)
SMTP_SECURE=false                            # true for port 465, false otherwise
SMTP_USER=                                   # SMTP username
SMTP_PASS=                                   # SMTP password
SMTP_FROM=                                   # From address, e.g. "Tally <no-reply@tally.app>"
