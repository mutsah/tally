
generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Database Shemas

enum Role {
  USER
  ADMIN
}

enum AccountType {
  CASH
  BANK
  INVESTMENT
  MICROLOANS
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum TransactionKind {
  INCOME
  EXPENSE
  TRANSFER
  // Starting balance for a derived (CASH/BANK) account. Contributes to the
  // account balance like INCOME, but — like TRANSFER — is excluded from all
  // income/expense/spending aggregates. At most one per account (service-enforced).
  OPENING
}



model User {
  id String @id @default(uuid())
  email String @unique
  password String
  firstName String?
  lastName String?
  role Role @default(USER)
  refreshToken String?

  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  valuations   AccountValuation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

model Category {
  id       String       @id @default(uuid())
  userId   String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  kind     CategoryKind
  parentId String?
  // Self-relation, ONE level of nesting (enforced in the service). SetNull is a
  // DB safety net for the user-delete cascade; the API blocks deleting a parent
  // that still has children, so this never fires through normal deletes.
  parent   Category?    @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]   @relation("CategoryChildren")

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name, parentId])
  @@index([userId])
  @@map("categories")
}

model Account {
  id       String      @id @default(uuid())
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  type     AccountType
  archived Boolean     @default(false)

  // Transactions where this account is the source / the transfer destination.
  txFrom Transaction[] @relation("TxFrom")
  txTo   Transaction[] @relation("TxTo")

  // Manual value snapshots (INVESTMENT/MICROLOANS accounts only).
  valuations AccountValuation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

model Transaction {
  id     String          @id @default(uuid())
  userId String
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind   TransactionKind
  // Always POSITIVE. Direction is carried by `kind`, never by sign.
  amount Decimal         @db.Decimal(18, 2)
  date   DateTime
  note   String?

  // Source/owning account (required). For TRANSFER, `toAccountId` is the
  // destination (added next step). Cascade keeps a user-delete clean; the
  // account in-use guard (Phase 4) prevents casual loss of records.
  accountId   String
  account     Account  @relation("TxFrom", fields: [accountId], references: [id], onDelete: Cascade)
  toAccountId String?
  toAccount   Account? @relation("TxTo", fields: [toAccountId], references: [id], onDelete: Cascade)

  // Category (null for transfers). SetNull keeps the financial record if a
  // category is ever removed.
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
  @@index([accountId])
  @@index([toAccountId])
  @@index([categoryId])
  @@map("transactions")
}

model AccountValuation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Snapshot value (outstanding principal for microloans). >= 0. The LATEST
  // snapshot by asOf is the valued account's balance — transactions are ignored.
  value Decimal  @db.Decimal(18, 2)
  asOf  DateTime
  note  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, asOf])
  @@index([userId])
  @@index([accountId, asOf])
  @@map("account_valuations")
}

model ResetPassword {
  id String @id @default(uuid())
  email String @unique
  token String @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("reset_password")
}



