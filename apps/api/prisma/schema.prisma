
generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Database Shemas

enum Role {
  USER
  ADMIN
}

enum AccountType {
  CASH
  BANK
  INVESTMENT
  MICROLOANS
}



model User {
  id String @id @default(uuid())
  email String @unique
  password String
  firstName String?
  lastName String?
  role Role @default(USER)
  refreshToken String?

  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

model Account {
  id       String      @id @default(uuid())
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  type     AccountType
  archived Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

model ResetPassword {
  id String @id @default(uuid())
  email String @unique
  token String @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("reset_password")
}



